# ──────────────────────────────────────────────────────────────────────────────
# Garmin Health Dashboard — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ──────────────────────────────────────────────────────────────────────────────

# ── Garmin Connect credentials (required for real data) ──────────────────────
# Without these the app falls back to realistic mock/demo data automatically.
GARMIN_USERNAME=your_garmin_email@example.com
GARMIN_PASSWORD=your_garmin_password

# ── Garmin OAuth tokens (required only if your account has MFA/2FA enabled) ──
# Generate once with: node scripts/get-garmin-tokens.js
# The script handles the MFA email code interactively and auto-adds tokens to Vercel.
# Tokens last ~90 days; re-run the script when they expire.
# When these are set, username/password are used only for display (not for auth).
GARMIN_OAUTH1=
GARMIN_OAUTH2=

# ── Anthropic API key (optional — powers the AI weekly summary) ───────────────
# Get yours at: https://console.anthropic.com/settings/keys
# If not set, the AI Summary card is simply hidden. The rest of the app works normally.
ANTHROPIC_API_KEY=sk-ant-...

# ── Web Push / VAPID keys (optional — enables push notifications) ─────────────
# Generate with: node scripts/generate-vapid-keys.js
# If not set, push notifications are disabled but the app works normally.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:your@email.com
